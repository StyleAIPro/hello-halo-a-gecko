          "+          // Mark that we received history (to skip sending extra \\r)",
          "+          receivedHistoryRef.current = true",
          "           // Clear terminal first to avoid duplicate content",
          "           term.clear()",
          "           // Write the history output"
        ]
      }
    ],
    "userModified": false,
    "replaceAll": false
  }
}
